DATABASE_URL=postgresql+psycopg://baita:baita@localhost:5433/baita_coin
TEST_DATABASE_URL=postgresql+psycopg://baita:baita@localhost:5433/baita_coin_test

# Em producao, SEMPRE defina isso -- protege /v1/internal/* e /v1/admin/*.
# Vazio/ausente = protecao desligada (padrao local/teste, de proposito).
INTERNAL_API_KEY=

# "*" libera qualquer origem (ok pra abrir a API agora); troque pelo
# dominio real do app assim que ele existir, ex: https://seu-app.lovable.app
CORS_ALLOW_ORIGINS=*
